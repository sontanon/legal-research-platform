# URL of the mock legal research backend (the core engine).
LEGAL_BACKEND_URL=http://127.0.0.1:8000

# Where the MCP adapter listens (Streamable HTTP).
MCP_HOST=127.0.0.1
MCP_PORT=8001

# Optional bearer token for simple auth (e.g., for Claude Code --header).
# Set to empty to disable auth.
MCP_AUTH_TOKEN=

# Polling interval (ms) for the widget's get_status calls.
MCP_WIDGET_POLL_MS=1500

# Hold-open duration (ms) for get_status on three-tool profiles (Amazon Quick, etc.).
MCP_THREE_TOOL_HOLD_MS=25000

# Internal poll interval (s) during held-open get_status.
MCP_HOLD_POLL_INTERVAL_S=2
