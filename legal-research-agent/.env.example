# Copy to .env and adjust. All vars are prefixed MOCK_.

# Storage (DB-agnostic SQLModel). Swap to Postgres for the real backend:
# MOCK_DB_URL=postgresql+asyncpg://user:pass@localhost:5432/legal
MOCK_DB_URL=sqlite+aiosqlite:///./data/jobs.db

# Global acceleration for development. 0.01 makes a ~2m quick job take ~1.2s.
MOCK_TIME_SCALE=1.0

# Effort-tier durations (seconds): mean / sd / min / max.
MOCK_QUICK_MEAN_S=120
MOCK_QUICK_SD_S=15
MOCK_QUICK_MIN_S=60
MOCK_QUICK_MAX_S=180

MOCK_STANDARD_MEAN_S=300
MOCK_STANDARD_SD_S=60
MOCK_STANDARD_MIN_S=180
MOCK_STANDARD_MAX_S=600

MOCK_DEEP_MEAN_S=720
MOCK_DEEP_SD_S=180
MOCK_DEEP_MIN_S=300
MOCK_DEEP_MAX_S=1200

# Probability a job ends in `failed` instead of `completed`.
MOCK_FAILURE_PROB=0.05

# Progress reporting: random intervals between events. No reliable ETA is exposed.
MOCK_PROGRESS_INTERVAL_MEAN_S=8
MOCK_PROGRESS_INTERVAL_MIN_S=2

# Dev server host/port.
MOCK_HOST=127.0.0.1
MOCK_PORT=8000
